# Required until @cloudflare/next-on-pages declares peer support for Next 16
# (its peer range currently caps at next<=15.5.2, but this repo is on Next
# 16.2.10). Remove once that's fixed upstream.
#
# This also disables npm's automatic peer-dependency install, which is why
# @testing-library/dom (otherwise only a peer of @testing-library/react) is
# pinned as an explicit devDependency in package.json — without it, a clean
# `npm ci` silently drops it and breaks tsc/vitest.
legacy-peer-deps=true
